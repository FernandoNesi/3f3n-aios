# 3F3N Tracking — Environment Variables
# Copie para .env e preencha. Nunca commitar .env.

# Google Analytics 4 — ID da propriedade
GA4_ID=G-XXXXXXXXXX

# Google Analytics 4 — API Secret (para Measurement Protocol server-side via n8n)
GA4_API_SECRET=

# Meta Pixel
PIXEL_ID=0000000000000000

# Meta Conversions API (server-side via n8n)
META_CAPI_ACCESS_TOKEN=

# Webhook n8n — recebe o payload flat e espelha para GA4 MP + Meta CAPI
WEBHOOK_URL=https://n8n.3f3n.io/webhook/lead-capture

# TTL da persistência de UTMs em localStorage (dias)
UTM_TTL_DAYS=30

# Debug — força log verbose independente de ?debug_tracking=1
TRACKING_DEBUG=false
