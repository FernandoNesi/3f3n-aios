{
  "skill_id": "tracking-3f3n",
  "version": "3.0.0",
  "taxonomy": "AÇÃO EM API",
  "logic": "Zero-Shot CoT + ReAct",
  "owner": "AI OS 3F3N — Squad de Performance",
  "grounding_level": "LEVEL 1 Foundation",
  "status": "production-ready",

  "description": "Tracking core definitivo para landings 3F3N (capturaA/B/C/…). Uso em 1 linha via `initTracking({ page })`. Payload flat validado, dedup inteligente, safe retry com backoff, storage 3-tier, _fbp/_fbc automáticos, logs estruturados em JSON.",

  "one_liner_usage": "initTracking({ page: 'capturaA' });",

  "parameters": {
    "page": {
      "type": "string",
      "required": true,
      "enum_suggested": ["capturaA", "capturaB", "capturaC"],
      "description": "Identificador da landing. Vira `page_variation` em todo evento."
    },
    "ga4_id":       { "type": "string",  "source": "window.__ENV__.GA4_ID" },
    "pixel_id":     { "type": "string",  "source": "window.__ENV__.PIXEL_ID" },
    "webhook_url":  { "type": "url",     "source": "window.__ENV__.WEBHOOK_URL" },
    "ttl_days":     { "type": "integer", "default": 30 },
    "auto_page_view": { "type": "boolean", "default": true },
    "retry":        { "type": "object",  "default": { "attempts": 3, "backoffMs": 500 } }
  },

  "event_contract": {
    "description": "Padrão flat OBRIGATÓRIO. Validado antes de cada disparo — evento malformado lança `INVALID_PAYLOAD`.",
    "mandatory_fields": [
      "event_name",
      "page_variation",
      "utm_source",
      "utm_medium",
      "utm_campaign",
      "utm_content",
      "event_id",
      "timestamp"
    ],
    "auto_fields": [
      "utm_term", "page_path", "page_url",
      "session_id", "fbp", "fbc"
    ],
    "utm_fallback": {
      "utm_source": "direct", "utm_medium": "none",
      "utm_campaign": "organic", "utm_content": "none", "utm_term": "none"
    }
  },

  "production_hardening": {
    "payload_validation": "REQUIRED_PAYLOAD_FIELDS check throws INVALID_PAYLOAD antes do disparo",
    "dedup": {
      "click_window_ms": 3000,
      "once_ttl_ms": 31536000000,
      "release_on_failure": true,
      "api": "{ once: true } | { dedupKey, ttlMs }"
    },
    "retry": {
      "strategy": "exponential backoff (2^n * backoffMs)",
      "attempts": 3,
      "no_retry_on_4xx": true
    },
    "storage": "3-tier fallback: localStorage → sessionStorage → in-memory Map",
    "fbp_synthetic": "gera fb.1.{ts}.{rand} quando cookie ausente",
    "fbc_from_fbclid": "deriva _fbc de ?fbclid= quando cookie ausente",
    "logs": "JSON estruturado { ts, src, v, level, event, data } — grep-friendly",
    "debug_gate": "?debug_tracking=1 OU window.TRACKING_DEBUG=true",
    "init_idempotent": true
  },

  "public_api": {
    "initTracking({ page })": "Facade 1-linha (lê __ENV__, auto page_view)",
    "Tracking3F3N.init(config)": "API completa (config explícito)",
    "Tracking3F3N.track(name, extra?, opts?)": "Eventos não-conversão. opts: { once, dedupKey, ttlMs }",
    "Tracking3F3N.conversion(name, extra?, opts?)": "Webhook-first com retry. Promise.",
    "Tracking3F3N.reset()": "Limpa dedup map (dev)",
    "Tracking3F3N._debug()": "Snapshot do estado interno"
  },

  "outputs": {
    "core_script": "references/tracking-core.js",
    "snippet_init": "references/tracking-init-example.html",
    "env_template": ".env.example"
  },

  "references": [
    "references/tracking-core.js",
    "references/tracking-init-example.html",
    "references/ga4-measurement-protocol.md",
    "references/meta-pixel-events.md",
    "references/neurodesign-lcp-checklist.md"
  ],

  "changelog": [
    { "version": "3.0.0", "changes": [
      "Facade `initTracking({ page })` — uso em 1 linha",
      "Validação de payload pré-disparo (INVALID_PAYLOAD)",
      "Safe retry com backoff exponencial (no retry em 4xx)",
      "Dedup dual: TTL anti duplo-clique + once permanente",
      "Dedup lock liberado em falha (retry real)",
      "Storage 3-tier (localStorage → sessionStorage → memória)",
      "_fbp sintético + _fbc derivado de ?fbclid",
      "Logs estruturados JSON",
      "Auto page_view configurável",
      "Reset API para limpar dedup em dev"
    ]},
    { "version": "2.0.0", "changes": [
      "tracking-core.js substitui utm-persistence.js",
      "Payload flat com page_variation + 4 UTMs em todo evento",
      "Fallback de UTMs, event_id UUID, fire-once guard"
    ]},
    { "version": "1.0.0", "changes": ["Versão inicial"] }
  ]
}
